<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pathway Hernia Umbilikalis (3 Diagnosa)</title>
    <!-- Mermaid JS -->
    <script src="https://cdn.jsdelivr.net/npm/mermaid/dist/mermaid.min.js"></script>
    <style>
        body {
            background: #f0f4f8;
            font-family: 'Segoe UI', Roboto, sans-serif;
            margin: 0;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }
        .card {
            max-width: 1100px;
            width: 100%;
            background: white;
            border-radius: 28px;
            box-shadow: 0 20px 40px rgba(0,20,40,0.12);
            padding: 30px 20px;
            transition: all 0.3s;
        }
        h2 {
            text-align: center;
            color: #0b2d4b;
            font-weight: 600;
            margin-top: 0;
            margin-bottom: 8px;
            font-size: 2em;
            letter-spacing: -0.5px;
        }
        .sub {
            text-align: center;
            color: #2c3e50;
            margin-bottom: 30px;
            font-size: 1.1em;
            border-bottom: 2px dashed #ffb74d;
            padding-bottom: 15px;
        }
        .diagram-container {
            background: #fbfdff;
            border-radius: 24px;
            padding: 25px 10px;
            overflow-x: auto;
            border: 1px solid #e9eef2;
            box-shadow: inset 0 2px 5px rgba(0,0,0,0.02);
        }
        .mermaid {
            min-width: 800px;
            background: transparent;
        }
        .legend {
            display: flex;
            flex-wrap: wrap;
            gap: 30px;
            justify-content: center;
            margin-top: 35px;
            padding: 18px 25px;
            background: #eef2f6;
            border-radius: 60px;
        }
        .legend-item {
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 0.95rem;
            font-weight: 500;
        }
        .color-badge {
            width: 22px;
            height: 22px;
            border-radius: 8px;
        }
        .footer {
            text-align: center;
            margin-top: 20px;
            color: #6c7a89;
            font-size: 0.9rem;
        }
    </style>
</head>
<body>
<div class="card">
    <h2>🔍 PATHWAY HERNIA UMBILIKALIS</h2>
    <div class="sub">Fokus Diagnosa Keperawatan: Nyeri Akut • Risiko Infeksi • Ansietas</div>

    <div class="diagram-container">
        <div class="mermaid">
            flowchart TD
                %% AKAR PENYEBAB
                P1[Kelemahan otot dinding perut] --> T{Tekanan intraabdomen<br>meningkat}
                P2[Kebiasaan mengejan:<br>batuk kronis, konstipasi,<br>angkat berat, obesitas] --> T

                T --> Proses[Usus / omentum<br>terdorong keluar melalui pusar]
                Proses --> Gejala[Benjolan di pusar<br>hilang timbul]

                %% PERBURUKAN (FISIK)
                Gejala --> Memburuk[Benjolan semakin besar<br>dan tidak bisa masuk kembali]
                Memburuk --> JaringanTertekan[Pembuluh darah tertekan<br>suplai oksigen terganggu]
                JaringanTertekan --> NyeriNode[<strong>Nyeri Akut</strong>]
                JaringanTertekan --> Iskemia[Jaringan mengalami iskemia]
                Iskemia --> Nekrosis[Jaringan mati / nekrosis]
                Nekrosis --> InfeksiNode[<strong>Risiko Infeksi</strong>]

                %% DAMPAK PSIKOLOGIS
                Gejala --> CemasNode[<strong>Ansietas</strong>]
                Memburuk --> CemasNode
                JaringanTertekan --> CemasNode

                %% STYLING NODE DIAGNOSA (tanpa “berhubungan dengan”)
                style NyeriNode fill:#ffebee,stroke:#c62828,stroke-width:3px,color:#b71c1c
                style InfeksiNode fill:#fff3e0,stroke:#ef6c00,stroke-width:3px,color:#e65100
                style CemasNode fill:#e8eaf6,stroke:#3f51b5,stroke-width:3px,color:#1a237e

                %% WARNA LAINNYA
                style P1 fill:#e1f5fe,stroke:#0277bd
                style P2 fill:#e1f5fe,stroke:#0277bd
                style T fill:#fff9c4,stroke:#fbc02d
                style Proses fill:#fff9c4,stroke:#fbc02d
                style Gejala fill:#c8e6c9,stroke:#2e7d32
                style Memburuk fill:#ffe0b2,stroke:#e65100
                style JaringanTertekan fill:#ffccbc,stroke:#bf360c
                style Iskemia fill:#ffab91,stroke:#bf360c
                style Nekrosis fill:#ff8a80,stroke:#b71c1c
        </div>
    </div>

    <!-- Legenda -->
    <div class="legend">
        <div class="legend-item"><span class="color-badge" style="background:#e1f5fe;"></span> Faktor penyebab</div>
        <div class="legend-item"><span class="color-badge" style="background:#fff9c4;"></span> Proses & gejala awal</div>
        <div class="legend-item"><span class="color-badge" style="background:#ffe0b2;"></span> Perburukan</div>
        <div class="legend-item"><span class="color-badge" style="background:#ffccbc;"></span> Dampak fisik</div>
        <div class="legend-item"><span class="color-badge" style="background:#ffebee; border:2px solid #c62828;"></span> <strong>Nyeri Akut</strong></div>
        <div class="legend-item"><span class="color-badge" style="background:#fff3e0; border:2px solid #ef6c00;"></span> <strong>Risiko Infeksi</strong></div>
        <div class="legend-item"><span class="color-badge" style="background:#e8eaf6; border:2px solid #3f51b5;"></span> <strong>Ansietas</strong></div>
    </div>

    <div class="footer">
        ⚕️ Diagnosa ditampilkan tanpa etiologi • sesuai permintaan
    </div>
</div>

<script>
    mermaid.initialize({
        startOnLoad: true,
        theme: 'base',
        themeVariables: {
            'background': '#fbfdff',
            'primaryColor': '#ffffff',
            'primaryBorderColor': '#b0bec5',
            'lineColor': '#546e7a',
            'fontFamily': 'Segoe UI, sans-serif'
        },
        flowchart: {
            useMaxWidth: true,
            htmlLabels: true,
            curve: 'basis'
        }
    });
</script>
</body>
</html>
